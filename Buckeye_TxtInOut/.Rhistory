output = list(
qtile =  define_output(file = '.hru',
variable = 'QTILE',
unit = 1),
VWC10cm = define_output(file = '.hru',
variable = 'VWC10mm',
unit = 1),
VWC20cm = define_output(file = '.hru',
variable = 'VWC20mm',
unit = 1),
VWC50cm = define_output(file = '.hru',
variable = 'VWC50mm',
unit = 1),
wat_tbl = define_output(file = '.hru',
variable = 'wattblmm',
unit = 1),
STMP10cm = define_output(file = '.hru',
variable = 'SOLTMP3dc',
unit = 1),
STMP20cm = define_output(file = '.hru',
variable = 'SOLTMP4dc',
unit = 1),
STMP50cm = define_output(file = '.hru',
variable = 'SOLTMP5dc',
unit = 1)),
parameter = par_lhs,
n_thread = 4,
keep_folder = FALSE)
